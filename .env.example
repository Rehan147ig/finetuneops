# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Core application
NEXT_PUBLIC_APP_NAME="FineTuneOps"
APP_URL="http://localhost:3000"
NODE_ENV="development"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Database
# Local Docker default with connection pooling:
# 10 connections per Next.js instance. Increase if running multiple instances.
# postgresql://finetuneops:finetuneops@postgres:5432/finetuneops?schema=public&connection_limit=10&pool_timeout=20
DATABASE_URL="postgresql://finetuneops:finetuneops@localhost:5432/finetuneops?schema=public&connection_limit=10&pool_timeout=20"

# Redis
REDIS_URL="redis://localhost:6379"

# Demo bootstrap
RUN_DEMO_SEED="true"
DEMO_WORKSPACE_NAME="Can of Soup Labs"
DEMO_WORKSPACE_SLUG="can-of-soup-labs"
DEMO_PROJECT_NAME="Support Specialist v2"

# Authentication
GOOGLE_CLIENT_ID="google-oauth-client-id"
GOOGLE_CLIENT_SECRET="google-oauth-client-secret"
GITHUB_CLIENT_ID="github-oauth-client-id"
GITHUB_CLIENT_SECRET="github-oauth-client-secret"

# Billing and email
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
# Get this from Stripe Dashboard -> Developers -> Webhooks -> Reveal signing secret
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
RESEND_API_KEY="re_replace_me"
RESEND_FROM_EMAIL="FineTuneOps <onboarding@example.com>"
ENCRYPTION_KEY="replace-with-32-byte-secret"

# Provider credentials
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
HUGGINGFACE_API_KEY=""
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_TEAM_MONTHLY=""
STRIPE_PRICE_TEAM_ANNUAL=""

# Observability
LOG_LEVEL="info"
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
ADMIN_SECRET=""

# Internal Slack webhook for ops alerts (optional)
# Get from: Slack -> Apps -> Incoming Webhooks
# If not set, critical queue alerts are logged only
INTERNAL_SLACK_WEBHOOK=""

# Queue monitoring thresholds (optional)
QUEUE_INGEST_TRACE_WARNING_THRESHOLD="500"
QUEUE_INGEST_TRACE_CRITICAL_THRESHOLD="2000"
QUEUE_SCORE_DATASET_WARNING_THRESHOLD="50"
QUEUE_SCORE_DATASET_CRITICAL_THRESHOLD="200"
QUEUE_LAUNCH_FINETUNE_WARNING_THRESHOLD="20"
QUEUE_LAUNCH_FINETUNE_CRITICAL_THRESHOLD="50"
QUEUE_POLL_FINETUNE_WARNING_THRESHOLD="100"
QUEUE_POLL_FINETUNE_CRITICAL_THRESHOLD="500"
QUEUE_SEND_NOTIFICATION_WARNING_THRESHOLD="100"
QUEUE_SEND_NOTIFICATION_CRITICAL_THRESHOLD="500"

# Load testing configuration
# Only used when running npm run load-test
# Never use a real workspace API key here
LOAD_TEST_URL="http://localhost:3000"
LOAD_TEST_API_KEY="fto_test_loadtest"
