{
  "name": "finetuneops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker:dev": "npx ts-node src/workers/index.ts",
    "worker:start": "node dist/workers/index.js",
    "docker:dev": "docker-compose up",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.production.yml up -d",
    "docker:logs": "docker-compose logs -f",
    "docker:down": "docker-compose down",
    "docker:start": "sh ./scripts/docker-start.sh",
    "load-test": "ts-node scripts/load-test.ts",
    "load-test:ci": "set LOAD_TEST_URL=http://localhost:3000&& ts-node scripts/load-test.ts",
    "sdk:build": "npm run build --workspace=packages/sdk",
    "sdk:test": "npm test --workspace=packages/sdk",
    "sdk:publish": "npm publish --workspace=packages/sdk",
    "lint": "eslint .",
    "test": "vitest run && jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:e2e": "playwright test",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.6.0",
    "@sentry/nextjs": "^10.49.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.75.2",
    "ioredis": "^5.10.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.8.1",
    "redis": "^5.9.0",
    "resend": "^6.0.1",
    "stripe": "^18.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/supertest": "^7.2.0",
    "autocannon": "^8.0.0",
    "eslint": "9.37.0",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "prisma": "6.6.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
